global:
  scrape_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node'
    static_configs:
      - targets: ['{{ hostvars['web-01']['ansible_host'] }}:9100',
                  '{{ hostvars['web-02']['ansible_host'] }}:9100',]
  
  - job_name: 'nginx-log-exporter'
    static_configs:
      - targets: ['{{ hostvars['web-01']['ansible_host'] }}:4040',
                  '{{ hostvars['web-02']['ansible_host'] }}:4040']
